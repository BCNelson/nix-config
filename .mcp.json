        "--host",
        "charlie=bcnelson@charlie.b.nel.family",
        "--host",
        "ryuu=bcnelson@ryuu.llp.nel.family",
        "--host",
        "vor=bcnelson@vor.ck.nel.family"
      ]
    }
  }
}